#!/usr/bin/env python3
"""Smoke tests for tsd-season-plot.

These tests run the wrapper script in-place from the repository checkout,
without installing it into ``$HOME/bin`` or the user site-packages.
"""

import os
import subprocess
import sys
import tempfile
import unittest
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]
SCRIPT = REPO_ROOT / "bin" / "bin" / "tsd-season-plot.py"


class TestTsdSeasonPlotCli(unittest.TestCase):
    """Exercise the installed-style wrapper against temporary TSD data."""

    def run_cli(self, *args, tsd_dir: Path) -> subprocess.CompletedProcess:
        """Run the CLI with a temporary TSD directory and Agg backend."""
        env = {
            **os.environ,
            "PYTHONPATH": str(REPO_ROOT / "src"),
            "MPLBACKEND": "Agg",
            "TSD": str(tsd_dir),
        }
        return subprocess.run(
            [sys.executable, str(SCRIPT), *args],
            capture_output=True,
            text=True,
            cwd=REPO_ROOT,
            env=env,
        )

    def test_year_mode_with_verbose_output(self):
        """Year mode should succeed and report the resolved data directory."""
        with tempfile.TemporaryDirectory() as tmpdir:
            tsd_dir = Path(tmpdir)
            (tsd_dir / "rain").write_text(
                "2024-01-01\t1\n2024-02-29\t3\n2025-01-10\t2\n",
                encoding="utf8",
            )

            result = self.run_cli(
                "rain",
                "--period",
                "year",
                "--no-month-lines",
                "--verbose",
                tsd_dir=tsd_dir,
            )

            self.assertEqual(result.returncode, 0, result.stderr)
            self.assertIn(
                f"Reading data from base directory: {tsd_dir}",
                result.stdout,
            )
            self.assertIn("Loaded 1 series containing 3 points", result.stdout)

    def test_sum_mode_accepts_multiple_files(self):
        """Multiple files should be loadable and summable in-place."""
        with tempfile.TemporaryDirectory() as tmpdir:
            tsd_dir = Path(tmpdir)
            (tsd_dir / "a").write_text("2024-01-01\t1\n", encoding="utf8")
            (tsd_dir / "b").write_text("2024-01-01\t2\n", encoding="utf8")

            result = self.run_cli(
                "a",
                "b",
                "--sum",
                "--period",
                "month",
                tsd_dir=tsd_dir,
            )

            self.assertEqual(result.returncode, 0, result.stderr)


if __name__ == "__main__":
    unittest.main()
