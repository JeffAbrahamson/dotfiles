class TestKalmanFilter(unittest.TestCase):

    def _kf(self, days, vals, **kw):
        defaults = dict(sigma_r=0.5, sigma_q=0.25, sigma_z=0.5)
        defaults.update(kw)
        return kalman_filter_random_walk_rate(
            np.array(days, dtype=float),
            np.array(vals, dtype=float),
            **defaults,
        )

    def test_single_observation_returns_prior(self):
        xT, PT = self._kf([0], [50])
        self.assertAlmostEqual(xT[0], 50.0)
        self.assertGreaterEqual(xT[1], 0.0)
        self.assertEqual(PT.shape, (2, 2))

    def test_rate_always_non_negative(self):
        # Quantity is increasing → filter should clip rate to 0
        xT, _ = self._kf(range(10), [50 + 2 * k for k in range(10)])
        self.assertGreaterEqual(xT[1], 0.0)

    def test_two_observations_non_negative_rate(self):
        xT, _ = self._kf([0, 10], [100, 90])
        self.assertGreaterEqual(xT[1], 0.0)

    def test_linear_signal_recovers_rate(self):
        # Perfect linear decrease of 1 unit/day; with low noise the filter
        # should converge close to the true rate of 1.0.
        t = list(range(21))
        z = [100.0 - k for k in t]
        xT, _ = self._kf(t, z, sigma_r=0.01, sigma_q=0.01, sigma_z=0.1)
        self.assertAlmostEqual(xT[1], 1.0, delta=0.1)

    def test_quantity_tracks_low_noise_observations(self):
        # With very low measurement noise, q_now should match the last reading.
        xT, _ = self._kf([0, 10], [100, 85], sigma_z=0.01)
        self.assertAlmostEqual(xT[0], 85.0, delta=0.5)

    def test_covariance_is_symmetric(self):
        _, PT = self._kf([0, 5, 10, 15], [100, 96, 91, 87])
        np.testing.assert_allclose(PT, PT.T, atol=1e-10)

    def test_covariance_is_positive_semidefinite(self):
        _, PT = self._kf([0, 5, 10, 15], [100, 96, 91, 87])
        eigenvalues = np.linalg.eigvalsh(PT)
        self.assertTrue(np.all(eigenvalues >= -1e-10))

    def test_longer_series_tightens_covariance(self):
        # More observations should reduce posterior uncertainty.
        _, PT_short = self._kf([0, 10], [100, 90])
        _, PT_long = self._kf(range(21), [100 - k for k in range(21)])
        self.assertLess(PT_long[0, 0], PT_short[0, 0])
        self.assertLess(PT_long[1, 1], PT_short[1, 1])


