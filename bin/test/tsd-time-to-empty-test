    def test_correct_day_intervals(self):
        t, _ = compute_time_axis(self.ROWS)
        np.testing.assert_array_equal(t, [0.0, 10.0, 20.0])

    def test_correct_quantities(self):
        _, q = compute_time_axis(self.ROWS)
