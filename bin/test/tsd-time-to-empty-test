    # -----------------------------------------------------------------------
    # Multi-file mode (positional args + $TSD_DIR)
    # -----------------------------------------------------------------------

    def _run_multi(self, files_data: dict, *args) -> subprocess.CompletedProcess:
        """Write files to a temp $TSD_DIR and run the script with positional args."""
        with tempfile.TemporaryDirectory() as tmpdir:
            for name, data in files_data.items():
                with open(os.path.join(tmpdir, name), "w") as fh:
                    fh.write(data)
            env = {**os.environ, "TSD_DIR": tmpdir}
            return subprocess.run(
                [sys.executable, str(SCRIPT), *files_data.keys(), *args],
                capture_output=True, text=True, env=env,
            )

    def test_multi_file_exits_zero(self):
        r = self._run_multi(
            {"alpha": SAMPLE_DATA, "beta": SAMPLE_DATA},
            "--seed", "42", "--nsims", "500",
        )
        self.assertEqual(r.returncode, 0, msg=r.stderr)

    def test_multi_file_section_headers_present(self):
        r = self._run_multi(
            {"alpha": SAMPLE_DATA, "beta": SAMPLE_DATA},
            "--seed", "42", "--nsims", "500",
        )
        self.assertIn("── alpha", r.stdout)
        self.assertIn("── beta",  r.stdout)

    def test_multi_file_summary_table_present(self):
        r = self._run_multi(
            {"alpha": SAMPLE_DATA},
            "--seed", "42", "--nsims", "500",
        )
        self.assertIn("Summary", r.stdout)
        self.assertIn("alpha",   r.stdout)

    def test_multi_file_no_single_file_header(self):
        # Multi-file mode must not emit the single-file "===" header
        r = self._run_multi(
            {"alpha": SAMPLE_DATA},
            "--seed", "42", "--nsims", "500",
        )
        self.assertNotIn("Time-to-Empty Forecast", r.stdout)

    def test_multi_file_summary_sorted_descending(self):
        # fast: ~3.3 units/day → median hitting time ~24 days
        # slow: ~0.17 units/day → median hitting time ~700 days
        # Table should list 'slow' before 'fast'.
        fast = "2025-03-01  120\n2025-03-07  100\n2025-03-13   80\n"
        slow = "2025-03-01  120\n2025-03-07  119\n2025-03-13  118\n"
        r = self._run_multi(
            {"fast": fast, "slow": slow},
            "--seed", "42", "--nsims", "2000",
        )
        self.assertEqual(r.returncode, 0, msg=r.stderr)
        summary_start = r.stdout.index("Summary")
        slow_pos = r.stdout.index("slow", summary_start)
        fast_pos = r.stdout.index("fast", summary_start)
        self.assertLess(slow_pos, fast_pos,
                        msg="'slow' should appear before 'fast' in the descending table")

