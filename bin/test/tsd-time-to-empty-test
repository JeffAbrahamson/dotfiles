class TestAsciiHistogram(unittest.TestCase):

    def test_all_inf_returns_message(self):
        result = ascii_histogram(np.array([np.inf, np.inf]), bins=5)
        self.assertIn("no depletion", result)

    def test_line_count_equals_bins(self):
        data = np.linspace(1.0, 100.0, 200)
        lines = ascii_histogram(data, bins=10).strip().split("\n")
        self.assertEqual(len(lines), 10)

    def test_tallest_bin_has_full_width_bar(self):
        # All identical values → one bin is tallest → full bar of `width` blocks
        data = np.full(100, 42.0)
        result = ascii_histogram(data, bins=1, width=15)
        self.assertIn("█" * 15, result)

    def test_empty_bin_has_no_bar_characters(self):
        # Bimodal data with a gap in the middle forces the inner bins to be
        # empty when using 4 bins.
        data = np.array([10.0, 11.0, 90.0, 91.0])
        lines = ascii_histogram(data, bins=4).strip().split("\n")
        self.assertNotIn("█", lines[1])   # second bin is empty
        self.assertNotIn("█", lines[2])   # third bin is empty

    def test_output_lines_contain_day_label(self):
        data = np.array([10.0, 20.0, 30.0])
        result = ascii_histogram(data, bins=3)
        self.assertIn(" d |", result)

    def test_inf_values_are_excluded(self):
        data = np.array([10.0, 20.0, np.inf, 30.0, np.inf])
        lines = ascii_histogram(data, bins=3).strip().split("\n")
        # Only finite values contribute; histogram should still have 3 bins
        self.assertEqual(len(lines), 3)

    def test_custom_bar_width(self):
        data = np.linspace(1.0, 50.0, 100)
        result = ascii_histogram(data, bins=5, width=30)
        # Bar cannot exceed width=30 characters
        for line in result.split("\n"):
            bar_section = line.split("|", 1)[1] if "|" in line else ""
            self.assertLessEqual(bar_section.count("█"), 30)

    def test_hist_min_zero_shows_empty_leading_bins(self):
        # Data from 50–100 with hist_min=0 (default): the first half of the
        # bins should be empty because no hitting times fall before day 50.
        data = np.linspace(50.0, 100.0, 200)
        lines = ascii_histogram(data, bins=10, hist_min=0.0).strip().split("\n")
        self.assertEqual(len(lines), 10)
        for i in range(5):
            self.assertNotIn("█", lines[i])   # empty bins before the data
        for i in range(5, 10):
            self.assertIn("█", lines[i])      # bins that contain data

    def test_auto_size_omits_empty_leading_region(self):
        # With auto_size the axis starts near the actual data, not at 0.
        data = np.linspace(50.0, 100.0, 100)
        lines_auto    = ascii_histogram(data, bins=5, auto_size=True).strip().split("\n")
        lines_default = ascii_histogram(data, bins=5).strip().split("\n")
        self.assertIn("█", lines_auto[0])       # first bin has data
        self.assertNotIn("█", lines_default[0]) # default hist_min=0 → empty leading bin

    def test_non_fractional_has_integer_edges(self):
        # With fractional=False, the edge values printed must be integers (no ".").
        data = np.linspace(1.0, 100.0, 200)
        result = ascii_histogram(data, bins=10, fractional=False)
        for line in result.strip().split("\n"):
            edge_part = line.split(" d |")[0]
            self.assertNotIn(".", edge_part)

    def test_non_fractional_bin_count_near_target(self):
        # Integer-snapped bins may differ slightly from the target but should
        # be in the same ballpark (within ±4 for a target of 10).
        data = np.linspace(1.0, 100.0, 300)
        lines = ascii_histogram(data, bins=10, fractional=False).strip().split("\n")
        self.assertGreater(len(lines), 6)
        self.assertLessEqual(len(lines), 14)


