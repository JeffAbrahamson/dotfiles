"""Tests for tsd-time-to-empty.py.

Covers unit tests for every public function and integration tests for the CLI.
"""

import importlib.util
import os
import subprocess
import sys
import tempfile
import unittest
from datetime import date
from pathlib import Path

import numpy as np

# ---------------------------------------------------------------------------
# Load the module under test (its filename contains hyphens)
# ---------------------------------------------------------------------------

SCRIPT = Path(__file__).resolve().parent.parent / "bin" / "tsd-time-to-empty.py"

spec = importlib.util.spec_from_file_location("tsd_time_to_empty", SCRIPT)
mod = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)

read_data = mod.read_data
compute_time_axis = mod.compute_time_axis
initial_rate_guess = mod.initial_rate_guess
kalman_filter_random_walk_rate = mod.kalman_filter_random_walk_rate
simulate_hitting_time = mod.simulate_hitting_time
ascii_histogram = mod.ascii_histogram

# ---------------------------------------------------------------------------
# Shared helpers / fixtures
# ---------------------------------------------------------------------------

SAMPLE_DATA = """\
2025-03-01   120
2025-03-09   112
2025-03-15   100
2025-03-30   98
2025-04-10   98
2025-04-22   90
"""


def write_temp(content: str) -> str:
    """Write *content* to a temporary file and return its path."""
    fd, path = tempfile.mkstemp(suffix=".txt")
    with os.fdopen(fd, "w") as fh:
        fh.write(content)
    return path


def run_script(*args, data: str = SAMPLE_DATA) -> subprocess.CompletedProcess:
    """Run tsd-time-to-empty.py against a temp data file; return the result."""
    path = write_temp(data)
    try:
        return subprocess.run(
            [sys.executable, str(SCRIPT), "-f", path, *args],
            capture_output=True,
            text=True,
        )
    finally:
        os.unlink(path)


