        r = run_script("--seed", "42", "--nsims", "500",
                       data="2025-03-01   100\n2025-03-11   90\n")
        self.assertEqual(r.returncode, 0)
        self.assertIn("Readings: 2", r.stdout)

    def test_unsorted_input_matches_sorted_output(self):
        sorted_d = "2025-03-01   120\n2025-03-09   112\n2025-03-15   100\n"
        unsorted_d = "2025-03-15   100\n2025-03-01   120\n2025-03-09   112\n"
        r_sorted = run_script("--seed", "42", "--nsims", "500", data=sorted_d)
        r_unsorted = run_script("--seed", "42", "--nsims", "500", data=unsorted_d)
        self.assertEqual(r_sorted.stdout, r_unsorted.stdout)

    def test_default_drops_same_day_duplicates(self):
