class TestSimulateHittingTime(unittest.TestCase):

    def _sim(self, q0, r0, *, nsims=300, sigma_r=0.0, sigma_q=0.0,
             dt=1.0, max_days=100.0, allow_neg=False, min_rate=0.0, seed=42):
        P = np.diag([1e-10, 1e-10])   # tiny uncertainty so initial state ≈ (q0, r0)
        return simulate_hitting_time(
            x_mean=np.array([q0, r0]),
            P=P,
            nsims=nsims,
            sigma_r=sigma_r,
            sigma_q=sigma_q,
            dt_forward=dt,
            max_days=max_days,
            rng=np.random.default_rng(seed),
            allow_negative_rate=allow_neg,
            min_rate=min_rate,
        )

    def test_output_shape(self):
        hits = self._sim(10.0, 1.0, nsims=500)
        self.assertEqual(hits.shape, (500,))

    def test_high_rate_all_hit_first_step(self):
        # q=10, r=20: after one step q = 10 - 20*1 = -10 → depleted
        hits = self._sim(10.0, 20.0, dt=1.0, max_days=5.0)
        np.testing.assert_array_equal(hits, 1.0)

    def test_zero_rate_no_noise_all_censored(self):
        # q=1000, r=0, no noise: quantity never decreases
        hits = self._sim(1000.0, 0.0, sigma_r=0.0, sigma_q=0.0,
                         allow_neg=False, min_rate=0.0, max_days=50.0)
        self.assertTrue(np.all(hits == np.inf))

    def test_censored_paths_recorded_as_inf(self):
        hits = self._sim(1000.0, 0.0, max_days=10.0)
        self.assertTrue(np.all(~np.isfinite(hits)))

    def test_hitting_time_close_to_expected(self):
        # q=20, r=1/day → expected depletion at ~20 days
        hits = self._sim(20.0, 1.0, nsims=1000, max_days=60.0)
        finite = hits[np.isfinite(hits)]
        self.assertGreater(len(finite), 900)
        self.assertAlmostEqual(float(np.median(finite)), 20.0, delta=3.0)

    def test_seed_produces_identical_results(self):
        P = np.diag([0.5, 0.1])
        kwargs = dict(
            x_mean=np.array([50.0, 2.0]), P=P, nsims=200,
            sigma_r=0.1, sigma_q=0.05, dt_forward=1.0, max_days=100.0,
            allow_negative_rate=False, min_rate=0.0,
        )
        h1 = simulate_hitting_time(**kwargs, rng=np.random.default_rng(7))
        h2 = simulate_hitting_time(**kwargs, rng=np.random.default_rng(7))
        np.testing.assert_array_equal(h1, h2)

    def test_different_seeds_produce_different_results(self):
        P = np.diag([0.5, 0.1])
        kwargs = dict(
            x_mean=np.array([50.0, 2.0]), P=P, nsims=200,
            sigma_r=0.1, sigma_q=0.05, dt_forward=1.0, max_days=100.0,
            allow_negative_rate=False, min_rate=0.0,
        )
        h1 = simulate_hitting_time(**kwargs, rng=np.random.default_rng(1))
        h2 = simulate_hitting_time(**kwargs, rng=np.random.default_rng(2))
        self.assertFalse(np.array_equal(h1, h2))

    def test_allow_negative_rate_runs_without_error(self):
        hits = self._sim(10.0, -2.0, allow_neg=True, max_days=20.0)
        self.assertEqual(hits.shape, (300,))

    def test_min_rate_forces_depletion(self):
        # With min_rate=1.0, even a zero initial rate gets floored to 1.
        # q=5 at rate ≥ 1/day depletes within 6 steps.
        hits = self._sim(5.0, 0.0, allow_neg=False, min_rate=1.0,
                         dt=1.0, max_days=20.0)
        self.assertTrue(np.all(np.isfinite(hits)))
        self.assertTrue(np.all(hits <= 6.0))

    def test_sigma_q_scales_with_sqrt_dt(self):
        # With correct sqrt(dt) scaling, changing dt should not shift the
        # median hitting time — the diffusion rate stays the same.
        P = np.diag([0.01, 0.001])
        base = dict(
            x_mean=np.array([50.0, 1.0]), P=P, nsims=8000,
            sigma_r=0.0, sigma_q=1.0, max_days=200.0,
            allow_negative_rate=False, min_rate=0.0,
        )
        h1 = simulate_hitting_time(**base, dt_forward=1.0,
                                   rng=np.random.default_rng(0))
        h2 = simulate_hitting_time(**base, dt_forward=2.0,
                                   rng=np.random.default_rng(0))
        f1 = h1[np.isfinite(h1)]
        f2 = h2[np.isfinite(h2)]
        # Medians should be within 5 days; std within 10 days
        self.assertAlmostEqual(float(np.median(f1)), float(np.median(f2)),
                               delta=5.0)
        self.assertAlmostEqual(float(np.std(f1)), float(np.std(f2)),
                               delta=10.0)

    def test_non_psd_covariance_handled_gracefully(self):
        # A near-singular P (not perfectly PSD) should not crash
        P = np.array([[1.0, 1.0], [1.0, 1.0]])  # rank-1, borderline PSD
        hits = simulate_hitting_time(
            x_mean=np.array([10.0, 1.0]), P=P, nsims=50,
            sigma_r=0.1, sigma_q=0.1, dt_forward=1.0, max_days=50.0,
            rng=np.random.default_rng(0), allow_negative_rate=False, min_rate=0.0,
        )
        self.assertEqual(hits.shape, (50,))


