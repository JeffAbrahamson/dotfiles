class TestReadData(unittest.TestCase):

    def _read(self, content, **kwargs):
        path = write_temp(content)
        try:
            return read_data(path, **kwargs)
        finally:
            os.unlink(path)

    def test_basic_parsing(self):
        rows = self._read(SAMPLE_DATA, drop_same_day_duplicates=True)
        self.assertEqual(len(rows), 6)
        self.assertEqual(rows[0], (date(2025, 3, 1), 120.0))
        self.assertEqual(rows[-1], (date(2025, 4, 22), 90.0))

    def test_sorts_by_date(self):
        content = "2025-03-15   100\n2025-03-01   120\n2025-03-09   112\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        dates = [d for d, _ in rows]
        self.assertEqual(dates, sorted(dates))

    def test_skips_blank_lines(self):
        content = "\n2025-03-01   120\n\n2025-03-09   112\n\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(len(rows), 2)

    def test_skips_comment_lines(self):
        content = "# header\n2025-03-01   120\n# note\n2025-03-09   112\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(len(rows), 2)

    def test_skips_malformed_date(self):
        # Wrong date format: should be skipped
        content = "03/01/2025   120\n2025-03-09   112\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(len(rows), 1)
        self.assertEqual(rows[0][0], date(2025, 3, 9))

    def test_skips_malformed_quantity(self):
        content = "2025-03-01   notanumber\n2025-03-09   112\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(len(rows), 1)
        self.assertEqual(rows[0][0], date(2025, 3, 9))

    def test_skips_lines_with_only_one_column(self):
        content = "2025-03-01\n2025-03-09   112\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(len(rows), 1)

    def test_dedup_keeps_last_reading_per_day(self):
        content = "2025-03-01   120\n2025-03-01   115\n2025-03-01   110\n"
        rows = self._read(content, drop_same_day_duplicates=True)
        self.assertEqual(len(rows), 1)
        self.assertEqual(rows[0][1], 110.0)

    def test_keep_same_day_retains_all_readings(self):
        content = "2025-03-01   120\n2025-03-01   115\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(len(rows), 2)

    def test_float_quantity_is_rounded_to_integer(self):
        content = "2025-03-01   36.6\n2025-03-09   37.0\n"
        rows = self._read(content, drop_same_day_duplicates=False)
        self.assertEqual(rows[0][1], 37.0)   # 36.6 → 37
        self.assertEqual(rows[1][1], 37.0)   # 37.0 → 37

    def test_exits_on_empty_file(self):
        path = write_temp("")
        try:
            with self.assertRaises(SystemExit):
                read_data(path, drop_same_day_duplicates=True)
        finally:
            os.unlink(path)

    def test_exits_when_all_lines_malformed(self):
        content = "# only comment\n\nbadline\n"
        path = write_temp(content)
        try:
            with self.assertRaises(SystemExit):
                read_data(path, drop_same_day_duplicates=True)
        finally:
            os.unlink(path)


