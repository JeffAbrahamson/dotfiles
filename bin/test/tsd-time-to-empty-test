class TestComputeTimeAxis(unittest.TestCase):

    ROWS = [
        (date(2025, 3, 1),  120.0),
        (date(2025, 3, 11), 110.0),
        (date(2025, 3, 21), 100.0),
    ]

    def test_first_time_is_zero(self):
