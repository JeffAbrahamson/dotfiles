#!/usr/bin/env python3

# Take two files generated by something like this
#
#    find ./ -type f -exec sum \{\} \; -print
#
# and output a list of files present not present in both.
# Note that the file format, then, is
#
#    number number
#    name
#
# repeated.

import sys


def read_file(filename):
    """Read a ``sum`` listing and return ``name -> checksum`` mapping."""

    mapping = {}
    with open(filename, "r", encoding="utf-8") as handle:
        value = handle.readline()
        while value:
            key = handle.readline()
            mapping[key.rstrip()] = value.rstrip()
            value = handle.readline()
    return mapping


def difference(first, second):
    """Print the elements in first changed or absent in second."""

    for name, checksum in first.items():
        if name in second:
            if checksum != second[name]:
                print("  Changed:", name)
        else:
            print("  Missing:", name)


def main():
    """Compare two ``sum`` listings and print differences."""

    if len(sys.argv) != 3:
        print(f"Usage: {sys.argv[0]} file1 file2")
        return 1
    filename1 = sys.argv[1]
    filename2 = sys.argv[2]
    first_map = read_file(filename1)
    second_map = read_file(filename2)

    print(f"Files in {filename1} but not in {filename2} (or changed)")
    difference(first_map, second_map)
    print(f"\nFiles in {filename2} but not in {filename1} (or changed)")
    difference(second_map, first_map)
    return 0

if __name__ == "__main__":
    main()
