#!/usr/bin/env python3

import argparse
import os
import re
import subprocess
import sys
from collections import defaultdict


def parse_args():
    parser = argparse.ArgumentParser(
        description=(
            "Search files under the current directory, but only print matches "
            "from files that contain every keyword."
        )
    )
    parser.add_argument(
        "-i",
        "--ignore-case",
        action="store_true",
        help="match keywords case-insensitively",
    )
    parser.add_argument(
        "keywords",
        nargs="+",
        help="literal keywords that must all occur somewhere in each result file",
    )
    return parser.parse_args()


def rg_files():
    try:
        result = subprocess.run(
            ["rg", "--files"],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except FileNotFoundError:
        return None

    if result.returncode not in (0, 1):
        return None

    return [line for line in result.stdout.splitlines() if line]


def find_files():
    files = rg_files()
    if files is not None:
        return files

    paths = []
    for root, dirs, filenames in os.walk("."):
        dirs[:] = [name for name in dirs if name != ".git"]
        for filename in filenames:
            path = os.path.join(root, filename)
            if path.startswith("./"):
                path = path[2:]
            paths.append(path)
    return sorted(paths)


def read_text(path):
    try:
        with open(path, "rb") as handle:
            data = handle.read()
    except OSError:
        return None

    if b"\0" in data:
        return None

    return data.decode("utf-8", errors="replace")


def keyword_in_text(keyword, text, ignore_case):
    if ignore_case:
        return keyword.casefold() in text.casefold()
    return keyword in text


def matching_lines(keyword, text, ignore_case):
    flags = re.IGNORECASE if ignore_case else 0
    pattern = re.compile(re.escape(keyword), flags)
    for number, line in enumerate(text.splitlines(), start=1):
        if pattern.search(line):
            yield number, line


def main():
    args = parse_args()
    matches_by_file = defaultdict(list)

    for path in find_files():
        text = read_text(path)
        if text is None:
            continue

        if not all(keyword_in_text(keyword, text, args.ignore_case) for keyword in args.keywords):
            continue

        for keyword in args.keywords:
            for line_number, line in matching_lines(keyword, text, args.ignore_case):
                matches_by_file[path].append((line_number, line))

    if not matches_by_file:
        return 1

    for path in sorted(matches_by_file):
        seen = set()
        for line_number, line in sorted(matches_by_file[path]):
            key = (line_number, line)
            if key in seen:
                continue
            seen.add(key)
            print(f"{path}:{line_number}:{line}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
