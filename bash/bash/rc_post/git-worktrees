#!/bin/bash

# Notes:
#
# Worktrees live under
# <main-git-dir>/worktrees-local/
#
# A branch like feature/foo becomes a directory like feature__foo
# (readable, collision-resistant enough for normal use).

# --- Git worktree helpers ----------------------------------------------------

# Print repo toplevel, or nothing if not in a repo.
__git_toplevel() {
  git rev-parse --show-toplevel 2>/dev/null
}

# Standard location + naming scheme for worktrees:
#   <main-git-dir>/worktrees-local/<branch-sanitized>
# Uses --git-common-dir so this works correctly from inside a linked worktree
# (where --show-toplevel points to the worktree root and .git is a file, not a dir).
__git_wt_base() {
  local common_dir
  common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return 1
  # --git-common-dir may return a relative path; make it absolute.
  if [[ "$common_dir" != /* ]]; then
    common_dir="$(cd "$common_dir" && pwd -P)" || return 1
  fi
  printf '%s/worktrees-local\n' "$common_dir"
}

# Sanitize branch name for filesystem paths (keeps it readable).
__git_wt_sanitize_branch() {
  local b="$1"
  # Replace slashes with __, and any other risky chars with _
  b="${b//\//__}"
  b="$(printf '%s' "$b" | sed -E 's/[^A-Za-z0-9._-]+/_/g')"
  printf '%s' "$b"
}

# Resolve worktree path for a branch name.
__git_wt_path_for_branch() {
  local base b
  base="$(__git_wt_base)" || return 1
  b="$(__git_wt_sanitize_branch "$1")"
  printf '%s/%s\n' "$base" "$b"
}

# List branch names (local + remote) that can be suggested.
__git_wt_list_branches() {
  # Local branches
  git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null
  # Remote branches (stripped to name after remote/)
  git for-each-ref --format='%(refname:short)' refs/remotes 2>/dev/null \
    | sed -E 's|^[^/]+/||' \
    | grep -v '^HEAD$' \
    | sort -u
}

# List existing worktrees as "<path>\t<branch>" (best-effort).
__git_wt_list_worktrees() {
  git worktree list --porcelain 2>/dev/null \
    | awk '
      $1=="worktree"{path=$2}
      $1=="branch"{branch=$2; sub("^refs/heads/","",branch); print path "\t" branch}
    '
}

# --- Public commands ---------------------------------------------------------

# gwt [-c [--from <ref>]] [-n] <branch>
# Creates or switches to a worktree for <branch>.
# - If worktree already exists, just cd into it.
# - If branch doesn't exist locally but exists on a remote, creates local tracking branch.
# - If branch doesn't exist anywhere, creates it off the current HEAD.
# -c: like git switch -c — branch must not already exist (explicit create).
# --from <ref>: starting point for new branch; requires -c.
# -n: don't cd into the worktree.
gwt() {
  local branch="" no_cd=0 create_new=0 from_ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        echo "Usage: gwt [-c [--from <ref>]] [-n] <branch>"
        echo ""
        echo "Create or switch to a worktree for <branch>."
        echo "  -c            Branch must not already exist (like git switch -c)"
        echo "  --from <ref>  Start new branch at <ref> instead of HEAD; requires -c"
        echo "  -n            Don't cd into the worktree"
        return 0 ;;
      -c)       create_new=1 ;;
      --from)   from_ref="${2:?'gwt: --from requires a <ref>'}"; shift ;;
      -n)       no_cd=1 ;;
      -*)       echo "gwt: unknown option: $1"; return 2 ;;
      *)        branch="$1" ;;
    esac
    shift
  done
  if [[ -z "$branch" ]]; then
    echo "Usage: gwt [-c [--from <ref>]] [-n] <branch>"
    return 2
  fi
  if [[ -n "$from_ref" && $create_new -eq 0 ]]; then
    echo "gwt: --from requires -c"
    return 2
  fi

  local top
  top="$(__git_toplevel)"
  if [[ -z "$top" ]]; then
    echo "Not in a git repo."
    return 1
  fi

  local wt_path base
  base="$(__git_wt_base)" || return 1
  wt_path="$(__git_wt_path_for_branch "$branch")" || return 1
  mkdir -p "$base" || return 1

  # -c: branch must not already exist.
  if [[ $create_new -eq 1 ]] && git show-ref --verify --quiet "refs/heads/$branch"; then
    echo "gwt: branch already exists: $branch"
    return 1
  fi

  # If a worktree already exists for this branch, cd there.
  local existing
  existing="$(__git_wt_list_worktrees | awk -F'\t' -v b="$branch" '$2==b{print $1; exit}')"
  if [[ -n "$existing" ]]; then
    if [[ $create_new -eq 1 ]]; then
      echo "gwt: worktree already exists for: $branch"
      return 1
    fi
    if [[ $no_cd -eq 0 ]]; then cd "$existing" || return 1; fi
    return 0
  fi

  # Ensure we have the branch locally; if only remote exists, create tracking branch.
  if ! git show-ref --verify --quiet "refs/heads/$branch"; then
    if [[ $create_new -eq 0 ]] && git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
      git branch --track "$branch" "origin/$branch" >/dev/null || return 1
    else
      # Create new branch from HEAD or --from ref
      git branch "$branch" "${from_ref:-HEAD}" >/dev/null || return 1
    fi
  fi

  # Create the worktree.
  git worktree add "$wt_path" "$branch" || return 1

  if [[ $no_cd -eq 0 ]]; then
    cd "$wt_path" || return 1
  fi
}

# gwtrm [<branch|path>] [-f] [-b]
# Removes a worktree by branch name (preferred) or by path.
# With no arguments, removes the worktree you are currently inside.
# -f: force removal of a worktree with uncommitted changes.
# -b: also delete the branch after removing the worktree.
#     Uses git branch -d (safe); combines with -f to use git branch -D.
gwtrm() {
  local target="" force="" delete_branch=0
  for arg in "$@"; do
    case "$arg" in
      -h|--help)
        echo "Usage: gwtrm [<branch|path>] [-f] [-b]"
        echo ""
        echo "Remove a worktree. With no argument, removes the current worktree."
        echo "  -f  Force removal even with uncommitted changes"
        echo "  -b  Also delete the branch (uses git branch -d; add -f for -D)"
        return 0 ;;
      -f|--force) force="--force" ;;
      -b)         delete_branch=1 ;;
      *)          [[ -z "$target" ]] && target="$arg" ;;
    esac
  done

  local top
  top="$(__git_toplevel)"
  if [[ -z "$top" ]]; then
    echo "Not in a git repo."
    return 1
  fi

  # No target given: use the worktree we're currently inside.
  if [[ -z "$target" ]]; then
    local main_wt cur_wt
    main_wt="$(git worktree list --porcelain 2>/dev/null | awk '$1=="worktree"{print $2; exit}')"
    cur_wt="$(__git_wt_list_worktrees | awk -F'\t' -v p="$PWD" '
      { wt=$1; if (wt==p || index(p, wt "/")==1) if (length(wt)>length(best)) best=wt }
      END { print best }
    ')"
    if [[ -z "$cur_wt" || "$cur_wt" == "$main_wt" ]]; then
      echo "Not inside a (non-main) worktree."
      return 1
    fi
    target="$cur_wt"
  fi

  local path=""
  if [[ "$target" == /* || "$target" == ./* || "$target" == ../* ]]; then
    path="$target"
  else
    # treat as branch
    path="$(__git_wt_list_worktrees | awk -F'\t' -v b="$target" '$2==b{print $1; exit}')"
    if [[ -z "$path" ]]; then
      # fall back to the standard path if it exists on disk
      local guess
      guess="$(__git_wt_path_for_branch "$target")"
      if [[ -d "$guess" ]]; then
        path="$guess"
      fi
    fi
  fi

  if [[ -z "$path" ]]; then
    echo "No worktree found for: $target"
    return 1
  fi

  # Capture branch name before the worktree is removed (needed for -b).
  local branch_to_delete=""
  if [[ $delete_branch -eq 1 ]]; then
    branch_to_delete="$(__git_wt_list_worktrees | awk -F'\t' -v p="$path" '$1==p{print $2; exit}')"
  fi

  # If we're inside the worktree being removed, move to the main worktree first.
  local pwd_real path_real
  pwd_real="$(cd "$PWD" 2>/dev/null && pwd -P)"
  path_real="$(cd "$path" 2>/dev/null && pwd -P)"

  if [[ -n "$pwd_real" && -n "$path_real" && "$pwd_real" == "$path_real"* ]]; then
    local dest
    dest="$(git worktree list --porcelain 2>/dev/null | awk '$1=="worktree"{print $2; exit}')"
    cd "${dest:-$HOME}" || cd "$HOME"
    pwd
  fi

  git worktree remove $force "$path" || return 1

  if [[ $delete_branch -eq 1 && -n "$branch_to_delete" ]]; then
    local branch_flag="-d"
    [[ -n "$force" ]] && branch_flag="-D"
    git branch $branch_flag "$branch_to_delete"
  fi
}

# gwtls
# List worktrees: short name and branch, current worktree marked with *.
unalias gwtls 2>/dev/null || true
gwtls() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: gwtls"
    echo ""
    echo "List worktrees with short names and branches."
    echo "Current worktree is marked with *. Main worktree shown as (main)."
    return 0
  fi

  local base cur_path main_path
  base="$(__git_wt_base)" || return 1
  cur_path="$(pwd -P 2>/dev/null)"
  main_path="$(git worktree list --porcelain 2>/dev/null | awk '$1=="worktree"{print $2; exit}')"

  git worktree list --porcelain 2>/dev/null | awk \
    -v base="${base}/" \
    -v cur="$cur_path" \
    -v main="$main_path" \
    'BEGIN { RS=""; FS="\n"; print "  " sprintf("%-28s", "NAME") "  BRANCH" }
    {
      path=""; branch="(detached)"
      for (i=1; i<=NF; i++) {
        if ($i ~ /^worktree /) { path=substr($i, 10) }
        if ($i ~ /^branch /)   { branch=substr($i, 8); sub("^refs/heads/","",branch) }
      }
      if (path == "") next
      name = path; sub(base, "", name)
      if (path == main) name = "(main)"
      marker = (cur == path || index(cur, path "/") == 1) ? "* " : "  "
      printf "%s%-28s  %s\n", marker, name, branch
    }'
}

# --- Bash completion ---------------------------------------------------------

# Complete gwt with branches; complete gwrm with existing worktree branches and paths.
__complete_gwt() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local top="$(__git_toplevel)"
  [[ -z "$top" ]] && return 0
  COMPREPLY=( $(compgen -W "$(__git_wt_list_branches)" -- "$cur") )
}

__complete_gwrm() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local top="$(__git_toplevel)"
  [[ -z "$top" ]] && return 0

  # Suggest both branch names that have worktrees and their paths.
  local items
  items="$(__git_wt_list_worktrees | awk -F'\t' '{print $2 "\n" $1}')"
  COMPREPLY=( $(compgen -W "$items" -- "$cur") )
}

complete -F __complete_gwt gwt
complete -F __complete_gwrm gwtrm

# Extra helper functions.

# Jump to the root of the current worktree.
cdgit() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: cdgit"
    echo ""
    echo "cd to the root of the current worktree."
    return 0
  fi
  local top
  top="$(git rev-parse --show-toplevel 2>/dev/null)" || { echo "Not in a git repo."; return 1; }
  cd "$top" || return 1
}
