# Bash completion for tsd-bicycle.

_tsd_bicycle() {
    local cur prev words cword
    _init_completion 2>/dev/null || {
        COMPREPLY=()
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"
        words=("${COMP_WORDS[@]}")
        cword=$COMP_CWORD
    }

    local commands="year bike plot-year plot-bike plot-cumulative"

    # Find the subcommand already given (first non-option word after tsd-bicycle).
    local subcommand=""
    local i
    for (( i=1; i<cword; i++ )); do
        case "${words[$i]}" in
            year|bike|plot-year|plot-bike|plot-cumulative)
                subcommand="${words[$i]}"
                break
                ;;
        esac
    done

    case "$subcommand" in
        plot-cumulative)
            case "$prev" in
                --comparison-year)
                    # Offer years found in bicycle data files.
                    local tsd_dir="${TSD_DIR:-$HOME/tsd}"
                    local years
                    years=$(awk '{print substr($1,1,4)}' "$tsd_dir"/bicycle-* 2>/dev/null \
                        | sort -u)
                    COMPREPLY=($(compgen -W "$years" -- "$cur"))
                    return 0
                    ;;
            esac
            COMPREPLY=($(compgen -W "--comparison-year" -- "$cur"))
            return 0
            ;;
        "")
            # No subcommand yet: complete on command names.
            COMPREPLY=($(compgen -W "$commands" -- "$cur"))
            return 0
            ;;
    esac
}

complete -F _tsd_bicycle tsd-bicycle
